<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <!-- Configuración de URL Rewrite para IIS -->
        <rewrite>
            <rules>
                <!-- Forzar HTTPS -->
                <rule name="Force HTTPS" stopProcessing="true">
                    <match url="(.*)" ignoreCase="false" />
                    <conditions>
                        <add input="{HTTPS}" pattern="off" ignoreCase="true" />
                    </conditions>
                    <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
                </rule>
                
                <!-- Redirección de www a no-www -->
                <rule name="Remove WWW" stopProcessing="true">
                    <match url="(.*)" ignoreCase="false" />
                    <conditions>
                        <add input="{HTTP_HOST}" pattern="^www\.(.*)$" />
                    </conditions>
                    <action type="Redirect" url="https://{C:1}/{R:1}" redirectType="Permanent" />
                </rule>
                
                <!-- Redirección de index.html a raíz -->
                <rule name="Remove Index" stopProcessing="true">
                    <match url="^(.*)index\.html$" ignoreCase="false" />
                    <action type="Redirect" url="{R:1}" redirectType="Permanent" />
                </rule>
                
                <!-- URLs amigables (opcional) -->
                <rule name="Friendly URLs" stopProcessing="false">
                    <match url="^([^/]+)/?$" ignoreCase="false" />
                    <conditions>
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="src/index.html" />
                </rule>
            </rules>
        </rewrite>
        
        <!-- Headers de seguridad -->
        <httpProtocol>
            <customHeaders>
                <!-- HSTS -->
                <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains; preload" />
                
                <!-- Protección XSS -->
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="X-Frame-Options" value="DENY" />
                <add name="X-XSS-Protection" value="1; mode=block" />
                
                <!-- CSP (Content Security Policy) -->
                <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'https://www.googletagmanager.com' 'https://www.clarity.ms' 'https://static.hotjar.com'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' 'https://www.googletagmanager.com' 'https://www.clarity.ms' 'https://static.hotjar.com'; frame-ancestors 'self';" />
                
                <!-- Cache Control -->
                <add name="Cache-Control" value="public, max-age=31536000" />
                
                <!-- CORS -->
                <add name="Access-Control-Allow-Origin" value="https://www.googletagmanager.com" />
                <add name="Access-Control-Allow-Origin" value="https://www.clarity.ms" />
                <add name="Access-Control-Allow-Origin" value="https://static.hotjar.com" />
            </customHeaders>
        </httpProtocol>
        
        <!-- Compresión -->
        <httpCompression directory="%SystemDrive%\inetpub\temp\IIS Temporary Compressed Files">
            <scheme name="gzip" dll="%Windir%\system32\inetsrv\gzip.dll" />
            <dynamicTypes>
                <add mimeType="text/*" enabled="true" />
                <add mimeType="message/*" enabled="true" />
                <add mimeType="application/javascript" enabled="true" />
                <add mimeType="application/json" enabled="true" />
                <add mimeType="application/ld+json" enabled="true" />
                <add mimeType="application/x-javascript" enabled="true" />
                <add mimeType="application/atom+xml" enabled="true" />
                <add mimeType="application/xaml+xml" enabled="true" />
                <add mimeType="*/*" enabled="false" />
            </dynamicTypes>
            <staticTypes>
                <add mimeType="text/*" enabled="true" />
                <add mimeType="message/*" enabled="true" />
                <add mimeType="application/javascript" enabled="true" />
                <add mimeType="application/json" enabled="true" />
                <add mimeType="application/ld+json" enabled="true" />
                <add mimeType="application/x-javascript" enabled="true" />
                <add mimeType="image/svg+xml" enabled="true" />
                <add mimeType="*/*" enabled="false" />
            </staticTypes>
        </httpCompression>
        
        <!-- Configuración de caché estática -->
        <staticContent>
            <!-- CSS -->
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
            <mimeMap fileExtension=".css" mimeType="text/css" />
            
            <!-- JavaScript -->
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
            <mimeMap fileExtension=".js" mimeType="application/javascript" />
            
            <!-- Imágenes -->
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
            <mimeMap fileExtension=".jpg" mimeType="image/jpeg" />
            <mimeMap fileExtension=".jpeg" mimeType="image/jpeg" />
            <mimeMap fileExtension=".png" mimeType="image/png" />
            <mimeMap fileExtension=".gif" mimeType="image/gif" />
            <mimeMap fileExtension=".webp" mimeType="image/webp" />
            <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
            <mimeMap fileExtension=".ico" mimeType="image/x-icon" />
            
            <!-- Fuentes -->
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
            <mimeMap fileExtension=".woff" mimeType="font/woff" />
            <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
            
            <!-- HTML -->
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="1.00:00:00" />
            <mimeMap fileExtension=".html" mimeType="text/html" />
            <mimeMap fileExtension=".htm" mimeType="text/html" />
            
            <!-- JSON y LD+JSON -->
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="1.00:00:00" />
            <mimeMap fileExtension=".json" mimeType="application/json" />
            <mimeMap fileExtension=".jsonld" mimeType="application/ld+json" />
            
            <!-- Manifest -->
            <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
            <mimeMap fileExtension=".manifest" mimeType="application/manifest+json" />
        </staticContent>
        
        <!-- Configuración de charset -->
        <httpEncoding>
            <scheme name="utf-8" />
        </httpEncoding>
        
        <!-- Configuración de timeouts -->
        <webLimits connectionTimeout="00:02:00" />
        
        <!-- Configuración de keep-alive -->
        <httpProtocol allowKeepAlive="true" maxKeepAliveRequests="100" />
        
        <!-- Ocultar firma del servidor -->
        <httpProtocol>
            <customHeaders>
                <add name="Server" value="IA Guide Server" />
            </customHeaders>
        </httpProtocol>
        
        <!-- Configuración de seguridad -->
        <security>
            <requestFiltering allowDoubleEscaping="true" maxAllowedUrlLength="4096" maxAllowedQueryStringLength="2048" />
        </security>
        
        <!-- Configuración de errores personalizados -->
        <httpErrors>
            <remove statusCode="404" subStatusCode="-1" />
            <error statusCode="404" path="/src/index.html" responseMode="ExecuteURL" />
        </httpErrors>
        
        <!-- Configuración de Service Worker -->
        <staticContent>
            <mimeMap fileExtension=".js" mimeType="application/javascript" />
        </staticContent>
        
        <!-- Configuración de PWA -->
        <staticContent>
            <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
        </staticContent>
    </system.webServer>
    
    <system.web>
        <!-- Configuración de charset -->
        <globalization fileEncoding="utf-8" requestEncoding="utf-8" responseEncoding="utf-8" culture="es-ES" uiCulture="es-ES" />
        
        <!-- Configuración de sesión -->
        <sessionState mode="InProc" timeout="20" />
        
        <!-- Configuración de compilation -->
        <compilation debug="false" targetFramework="4.5" />
    </system.web>
</configuration>
