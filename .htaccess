# Configuración de Apache para IA Guide
# Optimizado para rendimiento, seguridad y SEO

# Forzar HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Headers de seguridad
<IfModule mod_headers.c>
    # HSTS (HTTP Strict Transport Security)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Protección contra XSS
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"

    # Control de caché para archivos estáticos
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>

    # CORS para APIs externas
    Header set Access-Control-Allow-Origin "https://www.googletagmanager.com"
    Header set Access-Control-Allow-Origin "https://www.clarity.ms"
    Header set Access-Control-Allow-Origin "https://static.hotjar.com"
</IfModule>

# Compresión de archivos
<IfModule mod_deflate.c>
    SetOutputFilter DEFLATE
    
    # Tipos de archivos a comprimir
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/ld+json
</IfModule>

# Configuración de ETags
FileETag MTime Size

# Ocultar firma del servidor
ServerSignature Off

# Configuración de charset
AddDefaultCharset UTF-8

# Redirección de www a no-www (opcional)
# RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
# RewriteRule ^(.*)$ https://%1/$1 [L,R=301]

# Redirección de /index.html a /
RewriteCond %{THE_REQUEST} ^.*/index\.html
RewriteRule ^(.*)index\.html$ /$1 [R=301,L]

# URLs amigables (opcional, si se implementa)
# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteRule ^(.*)$ index.php [QSA,L]

# Seguridad adicional
<Files "config/*">
    Require all denied
</Files>

<Files "docs/*">
    Require all denied
</Files>

<Files ".htaccess">
    Require all denied
</Files>

<Files "*.log">
    Require all denied
</Files>

# Permitir acceso a archivos estáticos
<Directory "assets/*">
    Require all granted
</Directory>

<Directory "src">
    Require all granted
</Directory>

# Configuración de Service Worker
<Files "service-worker.js">
    AddType application/javascript .js
</Files>

# Configuración de manifest (PWA)
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
    AddType application/manifest+json .manifest.json
</IfModule>

# Optimización para SEO
<IfModule mod_rewrite.c>
    # Canonical URL automática
    RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [L,R=301]
    
    # Eliminar trailing slash
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)/$ /$1 [L,R=301]
</IfModule>

# Configuración de límites
LimitRequestBody 10485760
LimitRequestFields 100
LimitRequestFieldSize 8190

# Configuración de timeout
Timeout 300

# Configuración de keep-alive
KeepAlive On
KeepAliveTimeout 5
MaxKeepAliveRequests 100

# Configuración de compresión para Apache 2.4+
<IfModule mod_filter.c>
    AddOutputFilterByType DEFLATE text/css application/javascript application/json application/ld+json
</IfModule>
